# Coolify auto-generates these variables:
# SERVICE_USER_POSTGRES - random username
# SERVICE_PASSWORD_POSTGRES - random password
# SERVICE_FQDN_TRACCAR_8082 - public URL for the service

# Database
POSTGRESQL_DATABASE=traccar

# Traccar Configuration (optional)
CONFIG_USE_ENVIRONMENT_VARIABLES=true

# Additional Traccar settings (all optional)
# Format: SETTING_NAME=value (underscores replace dots)
# Examples:
# SERVER_FORWARD=true
# WEB_CONSOLE=true
# GEOCODER_ENABLE=true
# GEOCODER_TYPE=nominatim
# GEOCODER_URL=https://nominatim.openstreetmap.org/reverse
# MAIL_SMTP_HOST=smtp.example.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_STARTTLS_ENABLE=true
# MAIL_SMTP_FROM=traccar@example.com
# MAIL_SMTP_USERNAME=user
# MAIL_SMTP_PASSWORD=password
